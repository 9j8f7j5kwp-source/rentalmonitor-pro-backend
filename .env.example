# Database URL (Railway автоматически предоставит DATABASE_URL)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT Secret Key (сгенерируйте случайную строку)
JWT_SECRET_KEY=your-secret-key-here

# Flask Environment
FLASK_ENV=production

# CORS Origins (разрешённые домены, или * для всех)
CORS_ORIGINS=*
